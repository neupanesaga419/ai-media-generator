DEBUG=True
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Google Vertex AI (uses Application Default Credentials for auth)
# Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# xAI / Grok
XAI_API_KEY=




{
  "task": "autosize_photo_enhancement",
  "input": {
    "adjustments": {
      "retouching": {
        "facial_imperfections": {
          "remove": [
            "temporary blemishes",
            "acne",
            "dark spots",
            "uneven marks"
          ],
          "preserve": [
            "natural skin texture",
            "pores",
            "permanent moles",
            "birthmarks"
          ]
        }
      },
      "lighting": {
        "action": "enhance brightness and clarity",
        "style": "soft diffused studio lighting",
        "effect": "even illumination across face, no harsh shadows, balanced skin tones"
      }
    },
    "background_replacement": {
      "color_options": [
        "#0047AB",
        "#008080"
      ],
      "selection_criteria": "choose color with highest contrast against subject hair and clothing",
      "style": "solid matte background, no gradients, no textures"
    },
    "output_format": {
      "orientation": "vertical portrait",
      "framing_guidance": "keep extra margin around head and shoulders for later cropping",
      "resolution": "high",
      "color_profile": "sRGB"
    }
  }
}